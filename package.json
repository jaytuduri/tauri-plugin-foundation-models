{
  "name": "tauri-plugin-apple-intelligence-api",
  "version": "0.1.0",
  "description": "Frontend bindings for the Apple Intelligence Tauri plugin (macOS 26+)",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "./dist-js/index.cjs",
